// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "icon_theme": "Zed (Default)",
  "show_edit_predictions": false,
  "completions": {
    "lsp": true
  },
  "project_panel": {
    "dock": "left"
  },
  "outline_panel": {
    "dock": "left"
  },
  "collaboration_panel": {
    "dock": "left"
  },
  "git_panel": {
    "dock": "left"
  },
  "vim": {
    "toggle_relative_line_numbers": true
  },
  "agent": {
    "default_profile": "write",
    "sidebar_side": "right",
    "flexible": false,
    "dock": "right",
    "show_turn_stats": true,
    "tool_permissions": {
      "tools": {
        "copy_path": {
          "default": "allow"
        },
        "fetch": {
          "default": "allow"
        },
        "restore_file_from_disk": {
          "default": "allow"
        },
        "terminal": {
          "default": "allow",
          "always_allow": [
            {
              "pattern": "^cd\\s+py(\\s|$)"
            }
          ]
        }
      }
    },
    "default_model": {
      "provider": "Umans Coder",
      "model": "umans-coder",
      "enable_thinking": false
    },
    "favorite_models": [],
    "model_parameters": []
  },
  "language_models": {
    "openai_compatible": {
      "Umans Coder": {
        "api_url": "https://api.code.umans.ai/v1",
        "available_models": [
          {
            "name": "umans-coder",
            "max_tokens": 200000,
            "max_output_tokens": 32000,
            "max_completion_tokens": 200000,
            "capabilities": {
              "tools": true,
              "images": true,
              "parallel_tool_calls": true,
              "prompt_cache_key": true,
              "chat_completions": true,
              "interleaved_reasoning": false
            }
          }
        ]
      },
      "Umans AI": {
        "api_url": "https://api.code.umans.ai/v1",
        "available_models": [
          {
            "name": "umans-glm-5.2",
            "max_tokens": 200000,
            "max_output_tokens": 32000,
            "max_completion_tokens": 200000,
            "capabilities": {
              "tools": true,
              "images": true,
              "parallel_tool_calls": true,
              "prompt_cache_key": true,
              "chat_completions": true,
              "interleaved_reasoning": false
            }
          }
        ]
      }
    }
  },
  "agent_servers": {
    "opencode": {
      "default_config_options": {
        "effort": "high",
        "model": "umans-ai-coding-plan/umans-glm-5.2"
      },
      "type": "registry"
    },
    "claude-acp": {
      "type": "registry"
    }
  },
  "tab_bar": {
    "show": false
  },
  "title_bar": {
    "show_sign_in": false
  },
  "disable_ai": false,
  "telemetry": {
    "diagnostics": true,
    "metrics": false
  },
  "vim_mode": true,
  "ui_font_size": 15.0,
  "buffer_font_size": 14.0,
  "theme": {
    "mode": "dark",
    "light": "Gruvbox Light",
    "dark": "Gruvbox Dark Hard"
  }
}
